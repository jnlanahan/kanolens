{
  "name": "kanolens",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "AI-powered competitive analysis using the Kano Model (Dan Olsen's benefits-focused framing)",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "tsx watch --env-file=.env server/index.ts",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outfile=dist/server.js",
    "start": "NODE_ENV=production node dist/server.js",
    "check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "evals": "tsx --env-file=.env scripts/run-evals.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@electric-sql/pglite": "^0.4.4",
    "@google/genai": "^2.8.0",
    "@hono/node-server": "^1.19.5",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/node": "^10.56.0",
    "@sentry/react": "^10.56.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-router": "^1.168.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.0",
    "drizzle-zod": "^0.8.0",
    "hono": "^4.12.0",
    "jose": "^6.0.0",
    "langsmith": "^0.7.5",
    "lucide-react": "^1.8.0",
    "postgres": "^3.4.7",
    "posthog-js": "^1.383.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.73.0",
    "sonner": "^2.0.7",
    "stripe": "^22.2.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.0",
    "@tanstack/router-plugin": "^1.167.0",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.2.0",
    "drizzle-kit": "^0.31.0",
    "esbuild": "^0.28.0",
    "jsdom": "^27.0.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "vite": "^7.3.0",
    "vitest": "^3.2.0"
  }
}
