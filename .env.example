# KanoLens v2 environment
# Copy this file to `.env` and fill in real values. `.env` must never be committed.
#
# REQUIRED IN PRODUCTION (server refuses to boot without these):
#   NODE_ENV=production, DATABASE_URL, JWT_SECRET, ANTHROPIC_API_KEY, GEMINI_API_KEY
# STRONGLY RECOMMENDED IN PRODUCTION (features 503 without them):
#   PUBLIC_WEB_ORIGIN (your https URL), GOOGLE_CLIENT_ID/SECRET (sign-in),
#   STRIPE_SECRET_KEY/WEBHOOK_SECRET/PRICE_ID (billing)
#
# NODE_ENV: leave unset for local dev. Set to `production` on the deployed server.
# NODE_ENV=production

# --- Database -----------------------------------------------------------------
# Postgres 14+. Local docker example:
#   docker run --name kanolens-pg -e POSTGRES_USER=kanolens -e POSTGRES_PASSWORD=kanolens \
#     -e POSTGRES_DB=kanolens -p 5432:5432 -d postgres:17
DATABASE_URL=postgres://kanolens:kanolens@localhost:5432/kanolens

# --- Anthropic ----------------------------------------------------------------
# Used by the Analyst loop (Opus 4.8) and Scope Proposer (Opus 4.8).
# Generate at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Google AI ----------------------------------------------------------------
# Used by the Source Verifier (Gemini 2.5 Flash with Search Grounding).
# Generate at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Google OAuth -------------------------------------------------------------
# Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client (Web app).
# Authorized redirect URI (dev):  http://localhost:3001/api/auth/google/callback
# Authorized redirect URI (prod): https://<your-domain>/api/auth/google/callback
#   (derived from PUBLIC_WEB_ORIGIN below — they must match)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Auth ---------------------------------------------------------------------
# Random 32+ char string. Rotate on deploy. Example: openssl rand -hex 32
JWT_SECRET=

# --- Server / Web -------------------------------------------------------------
PORT=3001
WEB_PORT=5173
# Public URL the web app resolves against. In dev keep the localhost value.
# In production set this to your real https origin, e.g. https://kanolens.up.railway.app
# It drives both the CORS origin and the Google OAuth redirect URI.
PUBLIC_WEB_ORIGIN=http://localhost:5173

# --- Stripe -------------------------------------------------------------------
# Get keys at dashboard.stripe.com → Developers → API keys.
# Always start with test-mode keys (sk_test_...) and verify the full flow before using live keys.
# STRIPE_PRICE_ID: create a Product + Price in Stripe dashboard ($5 one-time), copy the price_... ID.
# STRIPE_WEBHOOK_SECRET: run `stripe listen --forward-to localhost:3001/api/payments/webhook`
#   and copy the whsec_... secret shown in the CLI output. In production, get it from
#   Stripe dashboard → Developers → Webhooks → your endpoint → Signing secret.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# --- Sentry -------------------------------------------------------------------
# Error tracking. Get DSN at sentry.io → your project → Settings → Client Keys.
# SENTRY_DSN is used by the server. VITE_SENTRY_DSN is used by the React frontend.
# Both values are the same DSN — just different variable names for server vs. browser.
SENTRY_DSN=
VITE_SENTRY_DSN=
# Auth token for uploading source maps during CI builds (org token, not project token).
# sentry.io → Settings → Auth Tokens → Create New Token (org:read, project:releases, project:read)
SENTRY_AUTH_TOKEN=

# --- PostHog ------------------------------------------------------------------
# Product analytics + session replay. Get keys at posthog.com → Settings → Project.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# --- LangSmith ----------------------------------------------------------------
# Required for running evals (npm run evals).
# Get your API key at smith.langchain.com → Settings → API Keys → Create API Key.
# LANGSMITH_ENDPOINT is omitted — the default (https://api.smith.langchain.com) is correct.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=KanoLens
