# Database Configuration
# Get your Supabase connection string from: https://app.supabase.com/project/YOUR_PROJECT/settings/database
# Use the "Connection string" tab and copy the URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# AI Service API Keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Add other API keys as needed
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Node Environment
NODE_ENV=development

# Session Secret (generate a random string)
SESSION_SECRET=your_session_secret_here

# Google OAuth Configuration (for Google Sign-In)
# Get this from: https://console.developers.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here