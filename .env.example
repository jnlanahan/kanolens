# KanoLens v2 environment
# Copy this file to `.env` and fill in real values. `.env` must never be committed.

# --- Database -----------------------------------------------------------------
# Postgres 14+. Local docker example:
#   docker run --name kanolens-pg -e POSTGRES_USER=kanolens -e POSTGRES_PASSWORD=kanolens \
#     -e POSTGRES_DB=kanolens -p 5432:5432 -d postgres:17
DATABASE_URL=postgres://kanolens:kanolens@localhost:5432/kanolens

# --- Anthropic ----------------------------------------------------------------
# Used by the Analyst loop (Opus 4.8) and Scope Proposer (Opus 4.8).
# Generate at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Google AI ----------------------------------------------------------------
# Used by the Source Verifier (Gemini 2.5 Flash with Search Grounding).
# Generate at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Google OAuth -------------------------------------------------------------
# Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client (Web app).
# Authorized redirect URI (dev): http://localhost:3001/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Auth ---------------------------------------------------------------------
# Random 32+ char string. Rotate on deploy. Example: openssl rand -hex 32
JWT_SECRET=

# --- Server / Web -------------------------------------------------------------
PORT=3001
WEB_PORT=5173
# Public URL the web app resolves against in prod (unset in dev = uses vite proxy).
PUBLIC_WEB_ORIGIN=http://localhost:5173

# --- Sentry -------------------------------------------------------------------
# Error tracking. Get DSN at sentry.io → your project → Settings → Client Keys.
# SENTRY_DSN is used by the server. VITE_SENTRY_DSN is used by the React frontend.
# Both values are the same DSN — just different variable names for server vs. browser.
SENTRY_DSN=
VITE_SENTRY_DSN=
# Auth token for uploading source maps during CI builds (org token, not project token).
# sentry.io → Settings → Auth Tokens → Create New Token (org:read, project:releases, project:read)
SENTRY_AUTH_TOKEN=

# --- PostHog ------------------------------------------------------------------
# Product analytics + session replay. Get keys at posthog.com → Settings → Project.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
